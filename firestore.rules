rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /patients/{id} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'valentinapauroca0@gmail.com';
    }
    match /sessions/{id} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'valentinapauroca0@gmail.com';
    }
  }
}
