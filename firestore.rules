rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función helper: acepta ambas formas del email (mayúscula/minúscula)
    function isValentina() {
      return request.auth != null && (
        request.auth.token.email == 'valentinapauroca0@gmail.com' ||
        request.auth.token.email == 'Valentinapauroca0@gmail.com'
      );
    }

    // Nicolás (desarrollador) también puede leer/escribir durante desarrollo
    function isNicolas() {
      return request.auth != null &&
        request.auth.token.email == 'nicoortizkok@gmail.com';
    }

    function canAccess() {
      return isValentina() || isNicolas();
    }

    match /patients/{id} {
      allow read, write: if canAccess();
    }
    match /sessions/{id} {
      allow read, write: if canAccess();
    }
    match /reports/{id} {
      allow read, write: if canAccess();
    }
  }
}
